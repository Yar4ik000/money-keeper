<?xml version="1.0" encoding="utf-8"?>
<!--
    Мы не позволяем ни cloud-backup, ни device-transfer забирать данные приложения:
    EncryptedSharedPreferences и биометрический wrap master_key опираются на Android
    Keystore, который НЕ переносится между устройствами. Перенос данных на другое
    устройство возможен только через ручной шифрованный бэкап (см. §9.5).
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="."/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="."/>
    </device-transfer>
</data-extraction-rules>

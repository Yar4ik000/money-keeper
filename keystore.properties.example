# Скопируй этот файл в keystore.properties (в корень проекта, рядом с этим файлом)
# и заполни реальными значениями. keystore.properties добавлен в .gitignore — секреты
# не попадут в репозиторий.
#
# Генерация keystore (один раз, на весь срок жизни проекта):
#
#   keytool -genkey -v \
#       -keystore moneykeeper-release.jks \
#       -alias moneykeeper \
#       -keyalg RSA \
#       -keysize 4096 \
#       -validity 18250 \
#       -storepass STRONG_PASSWORD \
#       -keypass STRONG_PASSWORD
#
# ВАЖНО: сохрани moneykeeper-release.jks и оба пароля в трёх местах:
#   1. рабочая машина (этот файл)
#   2. офлайн-носитель (USB-флешка в ящике стола)
#   3. менеджер паролей (Bitwarden / KeePassXC)
#
# Потеря keystore = невозможность обновлять приложение у всех, кому ты его отдал.

# Абсолютный путь до .jks-файла (или относительный от корня проекта)
storeFile=/absolute/path/to/moneykeeper-release.jks

# Пароль хранилища (storepass из keytool)
storePassword=REPLACE_WITH_STRONG_PASSWORD

# Alias ключа (значение параметра -alias из keytool)
keyAlias=moneykeeper

# Пароль ключа (keypass из keytool; можно совпадать со storePassword)
keyPassword=REPLACE_WITH_STRONG_PASSWORD
